root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{cpp,hpp,cu,cuh,h,c}]
indent_size = 2
max_line_length = 100

[*.py]
indent_size = 4
max_line_length = 100

[*.md]
trim_trailing_whitespace = false

[CMakeLists.txt]
indent_size = 2

[Makefile]
indent_style = tab
