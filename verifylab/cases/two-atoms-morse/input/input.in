# TDMD input file for two-atoms-morse VerifyLab case
#
# Format mirrors LAMMPS-metal units (Å, eV, ps, K).
# All keywords here are placeholders for the M1 input parser.

units           metal
boundary        p p p
atom_style      atomic

box             0.0 20.0   0.0 20.0   0.0 20.0
n_types         1
mass            1 1.0

create_atom     1   0.0  0.0  0.0
create_atom     1   2.5  0.0  0.0

pair_style      morse 8.0
pair_coeff      1 1   0.5  1.5  2.0

velocity        zero

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes

timestep        0.001
thermo          10
thermo_style    custom step temp pe ke etotal press
dump            d1 all custom 100 dump.lammpstrj id type x y z vx vy vz

run             1000
