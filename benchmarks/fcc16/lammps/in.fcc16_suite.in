# LAMMPS input — FCC16 benchmark suite (placeholder for M2)
#
# Variable `size` selects the system size: tiny | small | medium | large | huge.
# Run with: lmp -in in.fcc16_suite.in -var size small

variable        size index small

units           metal
boundary        p p p
atom_style      atomic

# Data file is generated by generate.py and placed in build/
read_data       ../../build/fcc16_${size}.lmps

# 16 atom types, all with mass ~58.7 g/mol (placeholder — real values come from
# the chosen NIST FeNiCrCo... EAM file at M2).
mass            * 58.7

# Placeholder for the real EAM file (M2 picks one of the NIST setfl alloys).
pair_style      eam/alloy
pair_coeff      * * fcc16.eam.alloy A B C D E F G H I J K L M N O P

velocity        all create 300.0 12345 mom yes rot yes dist gaussian

neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes

timestep        0.001

thermo          100
thermo_style    custom step temp pe ke etotal press

# 10k steps for the small size; scale up by hand for other sizes.
run             10000
