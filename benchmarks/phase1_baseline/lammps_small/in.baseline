# LAMMPS input: Phase 1 baseline for A/B comparison with TDMD.
# Must match TDMD small benchmark exactly:
#   Cu FCC 4000 atoms, Morse potential, NVE, dt=0.001 ps, 1000 steps.
#
# Morse parameters: D=0.3429 alpha=1.3588 r0=2.866 rc=6.0
# Velocity seed: 42, T_init=300K
# Units: metal (eV, Angstrom, ps, g/mol)

units           metal
atom_style      atomic
boundary        p p p

# Read the same FCC Cu box as TDMD small benchmark.
# Generate with: python3 tools/gen_fcc_data.py --elem Cu --a 3.615 --nx 10 --ny 10 --nz 10 -o small.data
read_data       ../small.data

# Morse pair potential — identical parameters to TDMD.
pair_style      morse 6.0
pair_coeff      1 1 0.3429 1.3588 2.866

# Neighbor list — Verlet with 1.0 A skin, same as TDMD.
neighbor        1.0 bin
neigh_modify    every 10 delay 0 check no

# Velocity initialization at 300K with seed 42, COM momentum removed.
velocity        all create 300.0 42 mom yes rot no

# NVE integration.
fix             1 all nve
timestep        0.001

# Thermo output every 100 steps.
thermo          100
thermo_style    custom step temp pe ke etotal press

# Run.
run             1000
