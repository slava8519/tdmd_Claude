# Phase C LAMMPS A/B: EAM (Mishin Cu), tiny (256-atom Cu FCC).
# Matches TDMD bench_pipeline_scheduler --size tiny --potential eam
#   --eam tests/data/Cu_mishin1.eam.alloy exactly.
#
# Same geometry, seed, timestep, neighbor settings as morse_tiny.in; the
# only difference is the pair style. Warmup 500, measured 5000.

units           metal
atom_style      atomic
boundary        p p p

read_data       ../tiny.data

pair_style      eam/alloy
pair_coeff      * * ../../../tests/data/Cu_mishin1.eam.alloy Cu

neighbor        1.0 bin
neigh_modify    every 10 delay 0 check no

velocity        all create 300.0 42 mom yes rot no

fix             1 all nve
timestep        0.001

thermo          500
thermo_style    custom step temp pe ke etotal

run             500

reset_timestep  0
run             5000
