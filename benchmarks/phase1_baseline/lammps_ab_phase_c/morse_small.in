# Phase C LAMMPS A/B: Morse, small (4000-atom Cu FCC).
# Matches TDMD bench_pipeline_scheduler --size small --potential morse exactly.

units           metal
atom_style      atomic
boundary        p p p

read_data       ../small.data

pair_style      morse 6.0
pair_coeff      1 1 0.3429 1.3588 2.866

neighbor        1.0 bin
neigh_modify    every 10 delay 0 check no

velocity        all create 300.0 42 mom yes rot no

fix             1 all nve
timestep        0.001

thermo          200
thermo_style    custom step temp pe ke etotal

# Warmup.
run             200

# Measured. Scrape "Loop time of X.XX on N procs for 2000 steps".
reset_timestep  0
run             2000
