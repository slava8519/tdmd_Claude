LAMMPS (2 Aug 2023 - Update 3)
package gpu 1
# Phase C LAMMPS A/B: Morse, medium (32000-atom Cu FCC).
# Matches TDMD bench_pipeline_scheduler --size medium --potential morse exactly.

units           metal
atom_style      atomic
boundary        p p p

read_data       ../medium.data
Reading data file ...
  orthogonal box = (0 0 0) to (72.3 72.3 72.3)
  1 by 1 by 1 MPI processor grid
  reading atoms ...
  32000 atoms
  read_data CPU = 0.024 seconds

pair_style      morse 6.0
pair_coeff      1 1 0.3429 1.3588 2.866

neighbor        1.0 bin
neigh_modify    every 10 delay 0 check no

velocity        all create 300.0 42 mom yes rot no

fix             1 all nve
timestep        0.001

thermo          100
thermo_style    custom step temp pe ke etotal

# Warmup.
run             100

