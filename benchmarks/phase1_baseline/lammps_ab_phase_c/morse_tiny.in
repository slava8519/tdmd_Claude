# Phase C LAMMPS A/B: Morse, tiny (256-atom Cu FCC).
# Matches TDMD bench_pipeline_scheduler --size tiny --potential morse exactly.
#
# Cu FCC 4x4x4 (256 atoms), Morse D=0.3429 alpha=1.3588 r0=2.866 rc=6.0,
# skin 1.0, rebuild_every 10, seed 42, T=300K, dt=0.001.
# Warmup 500 steps, measured 5000 steps — scrape "Loop time" from the
# SECOND `run` block.

units           metal
atom_style      atomic
boundary        p p p

read_data       ../tiny.data

pair_style      morse 6.0
pair_coeff      1 1 0.3429 1.3588 2.866

neighbor        1.0 bin
neigh_modify    every 10 delay 0 check no

velocity        all create 300.0 42 mom yes rot no

fix             1 all nve
timestep        0.001

thermo          500
thermo_style    custom step temp pe ke etotal

# Warmup.
run             500

# Measured block. Scrape "Loop time of X.XX on N procs for 5000 steps".
reset_timestep  0
run             5000
